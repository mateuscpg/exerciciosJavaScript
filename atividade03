var cadastro1 = {
nome:"Mateus Correia ",
idade: 20,
filiacao: ["Eugênio Pacelli","Maria José"],
  endereco: {
    rua:"Rua Fulano de Tal",
    cidade: "João Pessoa",
    estado:"Paraíba"
  },
dadosCompletos: function(){
  if (this.nome == "" || this.idade == "" || this.filiacao[0] == "" || this.filiacao[1] == "" || this.endereco.rua == "" || this.endereco.cidade == "" || this.endereco.estado == "")
    return false
  return true;
},
retorno: function(){
  if (this.dadosCompletos() == true){
    console.log("Todos os dados foram preenchidos");
  }
}
}


